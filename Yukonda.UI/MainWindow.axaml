<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="Yukonda.UI.MainWindow" Title="Yukonda.UI">
    <Window.Styles>
        <Style Selector="DockPanel.Connected">
            <Setter Property="IsVisible" Value="True"></Setter>
        </Style>
        <Style Selector="DockPanel.NotConnected">
            <Setter Property="IsVisible" Value="False"></Setter>
        </Style>

        <Style Selector="Border.connectionView">
            <Setter Property="Background" Value="LightGray"></Setter>
            <Setter Property="Padding" Value="20"></Setter>
            <Setter Property="CornerRadius" Value="0"></Setter>
            <Setter Property="BoxShadow" Value="0 5 20 20 #20000000"></Setter>
        </Style>

        <Style  Selector="Border.connectionView TextBox">
            <Setter Property="Background" Value="#FFFFFF"></Setter>
            <Setter Property="CornerRadius" Value="0"></Setter>
            <Setter Property="MinHeight" Value="2"></Setter>
            <Setter Property="FontSize" Value="10"></Setter>
            <Setter Property="Height" Value="24"></Setter>
            <Setter Property="BorderThickness" Value="0"></Setter>
        </Style>
        <Style  Selector="Border.connectionView ComboBox">
            <Setter Property="Background" Value="#FFFFFF"></Setter>
            <Setter Property="CornerRadius" Value="5"></Setter>
            <Setter Property="Height" Value="24"></Setter>
            <Setter Property="MinHeight" Value="2"></Setter>
            <Setter Property="Width" Value="200"></Setter>
            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
            <Setter Property="FontSize" Value="10"></Setter>
            <Setter Property="BorderThickness" Value="0"></Setter>
        </Style>

        <Style  Selector="TextBox:focus:focus /template/ Border">
            <Setter Property="Background" Value="goldenrod"></Setter>
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"></Setter>
            <Setter Property="BorderThickness" Value="0"></Setter>
            
        </Style>
    </Window.Styles>
    <Grid>
        <Border Classes="connectionView" DataContext="{Binding ConnectionView}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="300">
            <StackPanel Spacing="5">
                <Image Width="42"
                       Height="42">
                    <DrawingImage>
                        <DrawingImage.Drawing>
                            <DrawingGroup ClipGeometry="M0,0 V512 H512 V0 H0 Z">
                                <DrawingGroup Opacity="1">
                                    <DrawingGroup Opacity="1">
                                        <DrawingGroup Opacity="1">
                                            <DrawingGroup Opacity="1">
                                                <DrawingGroup Opacity="1">
                                                    <DrawingGroup Opacity="1">
                                                        <DrawingGroup Opacity="1">
                                                            <DrawingGroup Opacity="1">
                                                                <DrawingGroup Opacity="1">
                                                                    <DrawingGroup Opacity="1">
                                                                        <DrawingGroup Opacity="1">
                                                                            <DrawingGroup Opacity="1">
                                                                                <DrawingGroup Opacity="1">
                                                                                    <DrawingGroup Opacity="1">
                                                                                        <DrawingGroup Opacity="1">
                                                                                            <DrawingGroup Opacity="1">
                                                                                                <DrawingGroup Opacity="1">
                                                                                                    <DrawingGroup Opacity="1">
                                                                                                        <GeometryDrawing Brush="#FFF9710D">
                                                                                                            <GeometryDrawing.Geometry>
                                                                                                                <EllipseGeometry RadiusX="256" RadiusY="256" Center="256,256"/>
                                                                                                            </GeometryDrawing.Geometry>
                                                                                                        </GeometryDrawing>
                                                                                                    </DrawingGroup>
                                                                                                </DrawingGroup>
                                                                                            </DrawingGroup>
                                                                                        </DrawingGroup>
