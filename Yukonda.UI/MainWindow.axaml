                                        <GeometryDrawing Brush="#FFE5E1DC" Geometry="F1 M512,512z M0,0z M476.534,242.58C476.534,292.63,435.958,333.206,385.908,333.206L256,333.206 256,76.884C259.199,80.5 262.06,84.398 264.584,88.532 276.074,82.505 289.153,79.081 303.031,79.081 345.421,79.081 380.354,110.904 385.288,151.965L385.908,151.965C435.957,151.965,476.534,192.53,476.534,242.58z"/>
                                        <DrawingGroup Opacity="1">
                                            <GeometryDrawing Brush="#FF96928F" Geometry="F1 M512,512z M0,0z M132.418,209.538L379.581,209.538 379.581,415.292 132.418,415.292z"/>
                                            <GeometryDrawing Brush="#FF726E6B" Geometry="F1 M512,512z M0,0z M255.999,209.539L379.581,209.539 379.581,415.294 255.999,415.294z"/>
                                            <GeometryDrawing Brush="#FF96928F">
                                                <GeometryDrawing.Geometry>
                                                    <EllipseGeometry RadiusX="123.581" RadiusY="36.217" Center="256,209.538"/>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                            <DrawingGroup Opacity="1">
                                                <DrawingGroup Opacity="1">
                                                    <DrawingGroup Opacity="1">
                                                        <GeometryDrawing Brush="#FF726E6B" Geometry="F1 M512,512z M0,0z M379.582,209.539C379.582,229.537,324.249,245.756,256,245.756L256,173.321C324.249,173.322,379.582,189.532,379.582,209.539z"/>
