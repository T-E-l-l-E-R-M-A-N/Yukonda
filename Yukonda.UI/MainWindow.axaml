                                                    </DrawingGroup>
                                                </DrawingGroup>
                                            </DrawingGroup>
                                            <DrawingGroup Opacity="1">
                                                <DrawingGroup Opacity="1">
                                                    <DrawingGroup Opacity="1">
                                                        <GeometryDrawing Brush="#FFB7B4B2" Geometry="F1 M512,512z M0,0z M379.58,289.496L379.58,337.116C379.58,357.116,324.25,373.326,256,373.326L256,325.716C324.25,325.716,379.58,309.506,379.58,289.496z"/>
                                                    </DrawingGroup>
                                                </DrawingGroup>
                                            </DrawingGroup>
                                            <DrawingGroup Opacity="1">
                                                <DrawingGroup Opacity="1">
                                                    <DrawingGroup Opacity="1">
                                                        <GeometryDrawing Brush="#FFD8D5D2" Geometry="F1 M512,512z M0,0z M256,405.681C187.748,405.681,132.419,389.466,132.419,369.464L132.419,417.076C132.419,437.078 187.748,453.293 256,453.293 324.252,453.293 379.581,437.078 379.581,417.076L379.581,369.464C379.581,389.466,324.252,405.681,256,405.681z"/>
                                                    </DrawingGroup>
                                                </DrawingGroup>
                                            </DrawingGroup>
                                            <DrawingGroup Opacity="1">
                                                <DrawingGroup Opacity="1">
                                                    <DrawingGroup Opacity="1">
                                                        <GeometryDrawing Brush="#FFB7B4B2" Geometry="F1 M512,512z M0,0z M379.58,369.466L379.58,417.076C379.58,437.076,324.25,453.296,256,453.296L256,405.676C324.25,405.676,379.58,389.466,379.58,369.466z"/>
                                                    </DrawingGroup>
                                                </DrawingGroup>
                                            </DrawingGroup>
                                        </DrawingGroup>
                                        <DrawingGroup Opacity="1">
                                            <DrawingGroup Opacity="1">
                                                <DrawingGroup Opacity="1">
                                                    <GeometryDrawing Brush="#FFB7B4B2" Geometry="F1 M512,512z M0,0z M379.58,209.536L379.58,257.146C379.58,277.156,324.25,293.366,256,293.366L256,245.756C324.25,245.756,379.58,229.536,379.58,209.536z"/>
                                                </DrawingGroup>
                                            </DrawingGroup>
                                        </DrawingGroup>
                                    </DrawingGroup>
                                </DrawingGroup>
                            </DrawingGroup>
                        </DrawingImage.Drawing>
                    </DrawingImage>
                </Image>
                <TextBlock Text="Подключение к базе данных"
                           TextAlignment="Center"/>
                <ComboBox SelectedItem="{Binding DbProvider}">
                    <ComboBoxItem>SQLite</ComboBoxItem>
                    <ComboBoxItem>PostgreSQL</ComboBoxItem>
                </ComboBox>
                <TextBox Watermark="Host" Text="{Binding Host}"/>
                <TextBox Watermark="Port" Text="{Binding Port}"/>
                <TextBox Watermark="Username" Text="{Binding Username}"/>
                <TextBox Watermark="Password" PasswordChar="*" Text="{Binding Password}"/>
                <TextBox Watermark="Database" Text="{Binding Database}"/>
                <Button Command="{Binding $parent[Window].DataContext.ConnectCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>